<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="KRUX AI"
        android:textColor="@color/neon_cyan"
        android:textSize="22sp"
        android:textStyle="bold"
        android:paddingBottom="12dp" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:background="@color/panel_dark"
        android:padding="8dp">

        <TextView
            android:id="@+id/chatLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bienvenue sur KRUX.\nPose ta question ou envoie une image."
            android:textColor="@color/text_white"
            android:textSize="14sp" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="12dp">

        <EditText
            android:id="@+id/inputMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@color/panel_dark"
            android:hint="Écris ton message..."
            android:textColor="@color/text_white"
            android:textColorHint="@color/text_muted"
            android:padding="12dp"
            android:textSize="14sp" />

        <Button
            android:id="@+id/sendButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:backgroundTint="@color/neon_purple"
            android:text="Envoyer"
            android:textColor="@color/text_white" />
    </LinearLayout>

</LinearLayout>
