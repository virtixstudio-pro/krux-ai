<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="12dp">

    <RelativeLayout
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:paddingVertical="8dp">

        <TextView
            android:id="@+id/statusHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KRUX ONLINE // LLAMA 3.3"
            android:textColor="@color/neon_cyan"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_centerVertical="true"/>

        <Button
            android:id="@+id/logoutBtn"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:text="DÉCONNEXION"
            android:textSize="10sp"
            android:backgroundTint="@color/neon_pink"
            android:textColor="@color/text_white"/>
    </RelativeLayout>

    <ScrollView
        android:id="@+id/chatScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerBar"
        android:layout_above="@id/inputBar"
        android:layout_marginVertical="12dp">

        <TextView
            android:id="@+id/chatDisplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_white"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            android:fontFamily="monospace"/>
    </ScrollView>

    <LinearLayout
        android:id="@+id/inputBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/msgInput"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@color/panel_dark"
            android:hint="Commande..."
            android:textColorHint="@color/text_muted"
            android:textColor="@color/text_white"
            android:paddingHorizontal="12dp"/>

        <ImageButton
            android:id="@+id/sendBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:backgroundTint="@color/neon_purple"
            android:src="@android:drawable/ic_menu_send"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
</RelativeLayout>
